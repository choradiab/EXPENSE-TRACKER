<!DOCTYPE html>
<html>
<head>
  <title>Finance Tracker</title>
</head>
<body>
  <h2>Finance Tracker</h2>

  <form id="form">
    <select id="type">
      <option>Income</option>
      <option>Expense</option>
    </select>

    <select id="categoryType">
      <option>Household</option>
      <option>Office</option>
    </select>

    <input id="category" placeholder="Category" required />

    <select id="account">
      <option>Cash</option>
      <option>Savings</option>
      <option>Credit Card</option>
    </select>

    <input id="amount" type="number" placeholder="Amount" required />

    <input id="notes" placeholder="Notes" />

    <button type="submit">Save</button>
  </form>

  <script>
    const scriptURL = "PASTE_YOUR_GOOGLE_SCRIPT_URL_HERE";

    document.getElementById("form").addEventListener("submit", e => {
      e.preventDefault();

      const data = {
        type: document.getElementById("type").value,
        categoryType: document.getElementById("categoryType").value,
        category: document.getElementById("category").value,
        account: document.getElementById("account").value,
        amount: document.getElementById("amount").value,
        notes: document.getElementById("notes").value
      };

      fetch(scriptURL, {
        method: "POST",
        body: JSON.stringify(data)
      })
      .then(() => alert("Saved!"))
      .catch(() => alert("Error"));
    });
  </script>
</body>
</html>
